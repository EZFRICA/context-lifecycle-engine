# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- LLM provider (used by cle build / run / revalidate on the live path) ---
# Leave unset to keep the deterministic stub path (what the tests use).
LLM_PROVIDER=gemini                      # gemini | ollama
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3.1-flash-lite     # default; override to a model your key can reach

# Temperature for conversational solicitations (cle run) only.
# The FINGERPRINTER (cle build / revalidate) is always temperature=0 — not
# configurable by design. Changing temperature for probes would make the
# fingerprint non-deterministic and trigger spurious proof expiry.
# MAIN_TEMPERATURE=0.7                   # default; range 0.0–1.0

# --- Local fallback (Ollama) ---
# OLLAMA_MODEL=gemma:2b
# OLLAMA_BASE_URL=http://localhost:11434

# --- Op-log actor label (optional) ---
# CLE_ACTOR=your-name

# --- Weaviate Cloud (optional remote store backend) ---
# The default store is in-memory / on-disk (FileStore); Weaviate is opt-in
# and never required by the test suite.
# WCD_CLUSTER_URL=https://your-cluster.weaviate.cloud
# WCD_API_KEY=your-weaviate-key
